# Server Configuration
PORT=3000

# Security - CHANGE THESE IN PRODUCTION!
JWT_SECRET=super_secret_random_string_change_this_in_production

# Account Credentials
# For production, use strong passwords!
GUEST_PASSWORD=guest123
ADMIN_PASSWORD=admin123

# Frontend URL (used for CORS)
# For local development: http://localhost:5173
# For production: your actual domain, e.g., https://casasasa.example.com
FRONTEND_URL=http://localhost:5173

# Database path (relative to backend directory)
# Default: ./trips.db (SQLite file in backend folder)
DB_PATH=./trips.db

# File upload directory (relative to backend directory)
# Default: ./uploads
UPLOADS_DIR=./uploads
